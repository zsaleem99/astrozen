---
import Section from "./Section.astro";

const EMAIL = "zsaleem@naiadvent.com";

function reportMailto(reportName: string) {
  const subject = encodeURIComponent(`Request For ${reportName}`);
  const body = encodeURIComponent(
    `Hello,\n\nI'm reaching out as I'm interested in receiving the ${reportName} from your website. Can you please send me the latest edition?\n\nThank you.`
  );
  return `mailto:${EMAIL}?subject=${subject}&body=${body}`;
}
---

<Section text="Market Reports" href="reports">
  <p class="mb-10 -mt-6 max-w-2xl text-base text-neutral">
    We publish two flagship research reports — relied upon by investors,
    landlords, and occupiers to track the Calgary commercial property
    market. Request your copy below.
  </p>

  <div class="grid gap-6 md:grid-cols-2">
    <!-- Report 1: Quarterly Rent Survey -->
    <div
      class="flex flex-col rounded-2xl border border-border bg-card p-8 transition-colors duration-200 hover:border-primary/30"
    >
      <div
        class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl"
      >
        📋
      </div>
      <div
        class="mb-3 inline-block self-start rounded-full border border-primary/30 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary"
      >
        Quarterly Publication
      </div>
      <h3 class="mb-3 font-serif text-2xl font-bold text-white">
        Quarterly Rent Survey
      </h3>
      <p class="mb-6 flex-1 text-sm leading-relaxed text-neutral">
        Comprehensive rental data across Calgary's major commercial nodes —
        covering office, industrial, and retail sectors. Includes vacancy rates,
        rental growth trends, landlord incentives, and submarket breakdowns.
        Essential reading for landlords, tenants, and investors benchmarking
        their positions.
      </p>
      <ul class="mb-8 space-y-2">
        {
          [
            "Office, industrial & retail rental rates",
            "Vacancy rates by submarket",
            "Rental growth vs prior quarter",
            "Landlord incentive trends",
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm text-neutral">
              <span class="mt-0.5 text-primary">✓</span>
              {item}
            </li>
          ))
        }
      </ul>
      <a
        href={reportMailto("Quarterly Rent Survey")}
        class="inline-flex w-full items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-black transition-colors hover:bg-primary-dark"
      >
        Request Report
      </a>
    </div>

    <!-- Report 2: Quarterly Transaction Analysis -->
    <div
      class="flex flex-col rounded-2xl border border-border bg-card p-8 transition-colors duration-200 hover:border-primary/30"
    >
      <div
        class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl"
      >
        📊
      </div>
      <div
        class="mb-3 inline-block self-start rounded-full border border-primary/30 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary"
      >
        Quarterly Publication
      </div>
      <h3 class="mb-3 font-serif text-2xl font-bold text-white">
        Transaction Analysis & Market Insights
      </h3>
      <p class="mb-6 flex-1 text-sm leading-relaxed text-neutral">
        In-depth analysis of commercial property transactions completed during
        the quarter — sales volumes, capitalisation rates, buyer profiles, and
        emerging investment trends. Paired with forward-looking market insights
        to help stakeholders understand where the market is heading.
      </p>
      <ul class="mb-8 space-y-2">
        {
          [
            "Sales volumes & transaction counts",
            "Capitalisation rate movements",
            "Buyer & seller profile analysis",
            "Forward-looking market outlook",
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm text-neutral">
              <span class="mt-0.5 text-primary">✓</span>
              {item}
            </li>
          ))
        }
      </ul>
      <a
        href={reportMailto("Transaction Analysis & Market Insights")}
        class="inline-flex w-full items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-black transition-colors hover:bg-primary-dark"
      >
        Request Report
      </a>
    </div>
  </div>
</Section>
