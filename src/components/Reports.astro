---
import Section from "./Section.astro";
---

<Section text="Market Reports" href="reports">
  <p class="mb-10 -mt-6 max-w-2xl text-base text-neutral">
    We publish two flagship research reports — relied upon by investors,
    landlords, and occupiers to track the South African commercial property
    market. Request your copy below.
  </p>

  <div class="grid gap-6 md:grid-cols-2">
    <!-- Report 1: Quarterly Rent Survey -->
    <div
      class="flex flex-col rounded-2xl border border-border bg-card p-8 transition-colors duration-200 hover:border-primary/30"
    >
      <div
        class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl"
      >
        📋
      </div>
      <div
        class="mb-3 inline-block self-start rounded-full border border-primary/30 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary"
      >
        Quarterly Publication
      </div>
      <h3 class="mb-3 font-serif text-2xl font-bold text-white">
        Quarterly Rent Survey
      </h3>
      <p class="mb-6 flex-1 text-sm leading-relaxed text-neutral">
        Comprehensive rental data across Cape Town's major commercial nodes —
        covering office, industrial, and retail sectors. Includes vacancy rates,
        rental growth trends, landlord incentives, and submarket breakdowns.
        Essential reading for landlords, tenants, and investors benchmarking
        their positions.
      </p>
      <ul class="mb-8 space-y-2">
        {
          [
            "Office, industrial & retail rental rates",
            "Vacancy rates by submarket",
            "Rental growth vs prior quarter",
            "Landlord incentive trends",
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm text-neutral">
              <span class="mt-0.5 text-primary">✓</span>
              {item}
            </li>
          ))
        }
      </ul>
      <button
        type="button"
        data-modal-target="reports-modal"
        data-report="Quarterly Rent Survey"
        class="inline-flex w-full items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-black transition-colors hover:bg-primary-dark"
      >
        Request Report
      </button>
    </div>

    <!-- Report 2: Quarterly Transaction Analysis -->
    <div
      class="flex flex-col rounded-2xl border border-border bg-card p-8 transition-colors duration-200 hover:border-primary/30"
    >
      <div
        class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl"
      >
        📊
      </div>
      <div
        class="mb-3 inline-block self-start rounded-full border border-primary/30 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary"
      >
        Quarterly Publication
      </div>
      <h3 class="mb-3 font-serif text-2xl font-bold text-white">
        Transaction Analysis & Market Insights
      </h3>
      <p class="mb-6 flex-1 text-sm leading-relaxed text-neutral">
        In-depth analysis of commercial property transactions completed during
        the quarter — sales volumes, capitalisation rates, buyer profiles, and
        emerging investment trends. Paired with forward-looking market insights
        to help stakeholders understand where the market is heading.
      </p>
      <ul class="mb-8 space-y-2">
        {
          [
            "Sales volumes & transaction counts",
            "Capitalisation rate movements",
            "Buyer & seller profile analysis",
            "Forward-looking market outlook",
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm text-neutral">
              <span class="mt-0.5 text-primary">✓</span>
              {item}
            </li>
          ))
        }
      </ul>
      <button
        type="button"
        data-modal-target="reports-modal"
        data-report="Quarterly Transaction Analysis & Market Insights"
        class="inline-flex w-full items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-black transition-colors hover:bg-primary-dark"
      >
        Request Report
      </button>
    </div>
  </div>
</Section>

<!-- Reports request modal -->
<div
  id="reports-modal"
  class="modal-overlay hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Request a report"
>
  <div
    class="relative w-full max-w-lg rounded-2xl border border-border bg-card p-8 shadow-2xl"
  >
    <button
      type="button"
      data-modal-close
      class="absolute right-5 top-5 flex h-8 w-8 items-center justify-center rounded-full text-neutral transition-colors hover:bg-border hover:text-white"
      aria-label="Close"
    >
      ✕
    </button>

    <h3 class="mb-1 font-serif text-2xl font-bold text-white">
      Request a Report
    </h3>
    <p class="mb-6 text-sm text-neutral">
      Requesting: <strong class="text-primary" data-report-display
        >Market Report</strong
      >
    </p>

    <!--
      ACTION: Replace YOUR_FORM_ID with your Formspree form ID.
      Sign up free at https://formspree.io
    -->
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="space-y-4"
    >
      <input type="hidden" name="report" value="" />
      <input
        type="hidden"
        name="_subject"
        value="Report Request — NAI Advent"
      />

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="form-label" for="r-name">Full Name *</label>
          <input
            class="form-input"
            type="text"
            id="r-name"
            name="name"
            placeholder="John Smith"
            required
          />
        </div>
        <div>
          <label class="form-label" for="r-company">Company</label>
          <input
            class="form-input"
            type="text"
            id="r-company"
            name="company"
            placeholder="Acme Holdings"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="form-label" for="r-email">Email Address *</label>
          <input
            class="form-input"
            type="email"
            id="r-email"
            name="email"
            placeholder="john@example.com"
            required
          />
        </div>
        <div>
          <label class="form-label" for="r-phone">Phone Number</label>
          <input
            class="form-input"
            type="tel"
            id="r-phone"
            name="phone"
            placeholder="+27 21 000 0000"
          />
        </div>
      </div>

      <div>
        <label class="form-label" for="r-role">Your Role</label>
        <select class="form-input" id="r-role" name="role">
          <option value="">Select...</option>
          <option value="Investor">Investor</option>
          <option value="Landlord">Landlord</option>
          <option value="Tenant / Occupier">Tenant / Occupier</option>
          <option value="Developer">Developer</option>
          <option value="Banker / Financier">Banker / Financier</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <button
        type="submit"
        class="w-full rounded-full bg-primary py-3 text-sm font-semibold text-black transition-colors hover:bg-primary-dark"
      >
        Request Report
      </button>

      <p class="text-center text-xs text-neutral">
        The latest edition will be sent to your email address.
      </p>
    </form>
  </div>
</div>
