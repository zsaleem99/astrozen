---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;

const { socialLinks } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-border px-5 pt-10 pb-8">
  <div class="mx-auto max-w-6xl">
    <div class="mb-8 grid gap-8 sm:grid-cols-3">
      <!-- Brand -->
      <div>
        <p class="mb-1 font-serif text-lg font-bold text-white">NAI Advent</p>
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">
          Zohair Saleem
        </p>
        <p class="text-sm text-neutral">
          Commercial real estate advisory and brokerage services across all
          major asset classes.
        </p>
      </div>

      <!-- Services -->
      <div>
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-neutral">
          Services
        </p>
        <ul class="space-y-2">
          {
            [
              "Property Valuations",
              "Purchaser Representation",
              "Asset Disposition",
              "Market Intel & Data",
              "Consultancy",
            ].map((s) => (
              <li>
                <a
                  href="#services"
                  class="text-sm text-neutral transition-colors hover:text-primary"
                >
                  {s}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Quick links & contact -->
      <div>
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-neutral">
          Quick Links
        </p>
        <ul class="mb-6 space-y-2">
          {
            [
              { text: "Listings", href: "#listings" },
              { text: "Reports", href: "#reports" },
              { text: "Experience", href: "#experience" },
              { text: "About", href: "#about" },
              { text: "Contact", href: "#contact" },
            ].map(({ text, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-neutral transition-colors hover:text-primary"
                >
                  {text}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="flex gap-4">
          {
            socialLinks.map(({ text, href }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-medium text-neutral transition-colors hover:text-primary"
              >
                {text}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="border-t border-border pt-6 text-center">
      <p class="text-xs text-neutral">
        © {currentYear} NAI Advent — Zohair Saleem. All rights reserved.
      </p>
    </div>
  </div>
</footer>
