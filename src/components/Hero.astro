---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary } = Astro.props;
---

<section class="pb-24 pt-28 md:pt-36" id="hero">
  <p
    class="mb-4 font-sans text-sm font-semibold uppercase tracking-widest text-primary"
  >
    NAI Advent — Commercial Real Estate
  </p>
  <h1
    class="mb-3 font-serif text-6xl font-bold tracking-tightest text-white sm:text-7xl md:text-8xl"
  >
    {name}
  </h1>
  <p
    class="mb-8 font-serif text-3xl font-bold tracking-tighter text-primary sm:text-4xl md:text-5xl"
  >
    {specialty}
  </p>
  <p class="mb-12 max-w-2xl text-base font-normal leading-relaxed text-neutral md:text-lg">
    {summary}
  </p>

  <div class="flex flex-wrap gap-4">
    <a
      href="#services"
      class="inline-block rounded-full bg-primary px-8 py-4 text-sm font-semibold text-black transition-colors duration-200 hover:bg-primary-dark"
    >
      Our Services
    </a>
    <a
      href="#contact"
      class="inline-block rounded-full border border-primary/40 px-8 py-4 text-sm font-semibold text-primary transition-colors duration-200 hover:border-primary hover:text-white"
    >
      Get in Touch
    </a>
  </div>

  <!-- Stats bar -->
  <div
    class="mt-20 grid grid-cols-2 gap-6 border-t border-border pt-10 md:grid-cols-4"
  >
    <div>
      <p class="font-serif text-3xl font-bold text-white md:text-4xl">10+</p>
      <p class="mt-1 text-sm text-neutral">Years Experience</p>
    </div>
    <div>
      <p class="font-serif text-3xl font-bold text-white md:text-4xl">R2bn+</p>
      <p class="mt-1 text-sm text-neutral">Deal Volume</p>
    </div>
    <div>
      <p class="font-serif text-3xl font-bold text-white md:text-4xl">5</p>
      <p class="mt-1 text-sm text-neutral">Service Lines</p>
    </div>
    <div>
      <p class="font-serif text-3xl font-bold text-white md:text-4xl">400+</p>
      <p class="mt-1 text-sm text-neutral">NAI Global Offices</p>
    </div>
  </div>
</section>
