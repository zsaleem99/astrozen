---
import Section from "./Section.astro";
import type { ServiceProps } from "@types";

interface Props {
  services: ServiceProps[];
}

const { services } = Astro.props;
---

<Section text="Our Services" href="services">
  <p class="mb-10 -mt-6 max-w-2xl text-base text-neutral">
    We provide comprehensive commercial real estate advisory across five
    integrated service lines — each backed by deep market expertise and a
    commitment to client outcomes.
  </p>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      services.map((service) => (
        <div class="flex flex-col rounded-2xl border border-border bg-card p-7 transition-colors duration-200 hover:border-primary/30">
          <span class="mb-5 text-3xl">{service.icon}</span>
          <h3 class="mb-3 font-serif text-xl font-semibold text-white">
            {service.name}
          </h3>
          <p class="mb-6 flex-1 text-sm leading-relaxed text-neutral">
            {service.description}
          </p>
          <button
            type="button"
            data-modal-target="service-modal"
            data-service={service.name}
            class="mt-auto inline-flex w-full items-center justify-center rounded-full border border-primary/40 px-5 py-2.5 text-sm font-medium text-primary transition-all duration-200 hover:border-primary hover:bg-primary hover:text-black"
          >
            Request This Service
          </button>
        </div>
      ))
    }
  </div>
</Section>

<!-- Service inquiry modal -->
<div id="service-modal" class="modal-overlay hidden" role="dialog" aria-modal="true" aria-label="Request a service">
  <div class="relative w-full max-w-lg rounded-2xl border border-border bg-card p-8 shadow-2xl">
    <button
      type="button"
      data-modal-close
      class="absolute right-5 top-5 flex h-8 w-8 items-center justify-center rounded-full text-neutral transition-colors hover:bg-border hover:text-white"
      aria-label="Close"
    >
      ✕
    </button>

    <h3 class="mb-1 font-serif text-2xl font-bold text-white">
      Request a Service
    </h3>
    <p class="mb-6 text-sm text-neutral">
      Enquiring about: <strong class="text-primary" data-service-display>our services</strong>
    </p>

    <!--
      ACTION: Replace YOUR_FORM_ID with your Formspree form ID.
      Sign up free at https://formspree.io — create a form and paste the ID here.
    -->
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="space-y-4"
    >
      <input type="hidden" name="service" value="" />
      <input type="hidden" name="_subject" value="Service Enquiry — NAI Advent" />

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="form-label" for="s-name">Full Name *</label>
          <input
            class="form-input"
            type="text"
            id="s-name"
            name="name"
            placeholder="John Smith"
            required
          />
        </div>
        <div>
          <label class="form-label" for="s-company">Company</label>
          <input
            class="form-input"
            type="text"
            id="s-company"
            name="company"
            placeholder="Acme Holdings"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="form-label" for="s-email">Email Address *</label>
          <input
            class="form-input"
            type="email"
            id="s-email"
            name="email"
            placeholder="john@example.com"
            required
          />
        </div>
        <div>
          <label class="form-label" for="s-phone">Phone Number</label>
          <input
            class="form-input"
            type="tel"
            id="s-phone"
            name="phone"
            placeholder="+27 21 000 0000"
          />
        </div>
      </div>

      <div>
        <label class="form-label" for="s-message">Message</label>
        <textarea
          class="form-input min-h-[100px] resize-y"
          id="s-message"
          name="message"
          placeholder="Tell us more about your requirements..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-full bg-primary py-3 text-sm font-semibold text-black transition-colors hover:bg-primary-dark"
      >
        Send Enquiry
      </button>
    </form>
  </div>
</div>
