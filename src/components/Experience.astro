---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Experience" href="experience">
  {
    experience.map(({ company, position, startDate, endDate, summary }) => (
      <div class="mb-12 border-l-2 border-border pl-6 last:mb-0">
        <div class="mb-4">
          <h3 class="font-serif text-xl font-semibold text-white">{company}</h3>
          <h4 class="font-serif text-lg font-medium text-primary">{position}</h4>
          <span class="text-xs font-medium uppercase tracking-widest text-neutral/60">
            {startDate} — {endDate}
          </span>
        </div>
        {Array.isArray(summary) ? (
          <ul class="list-none space-y-3">
            {summary.map((log) => (
              <li class="relative pl-5 text-sm leading-relaxed text-neutral before:absolute before:left-0 before:top-2 before:h-1.5 before:w-1.5 before:rounded-full before:bg-primary/60 before:content-['']">
                {log}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-sm leading-relaxed text-neutral">{summary}</p>
        )}
      </div>
    ))
  }
</Section>
